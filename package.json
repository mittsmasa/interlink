{
  "name": "interlink",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:preview": "NEXT_PUBLIC_VERCEL_ENV=preview next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "prepare": "test -n \"$CI\" || next typegen",
    "type-check": "next typegen && tsc --noEmit",
    "check": "pnpm lint && pnpm type-check",
    "test": "vitest",
    "test:unit": "vitest run --project unit",
    "test:db": "vitest run --project db",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": "24.15.0"
  },
  "dependencies": {
    "@ai-sdk/react": "3.0.195",
    "@emulators/adapter-next": "0.6.1",
    "@emulators/google": "0.6.1",
    "@hono/zod-validator": "0.8.0",
    "@libsql/client": "0.17.3",
    "@phosphor-icons/react": "2.1.10",
    "@tailwindcss/postcss": "4.3.0",
    "@xyflow/react": "12.11.0",
    "ai": "6.0.193",
    "better-auth": "1.6.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "d3-force": "3.0.0",
    "drizzle-orm": "0.45.2",
    "elementary-circuits-directed-graph": "^1.3.1",
    "hono": "4.12.23",
    "mathjs": "^15.2.0",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "postcss": "8.5.15",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/d3-force": "3.0.10",
    "@types/elementary-circuits-directed-graph": "^1.3.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "lefthook": "2.1.8",
