# Turso DB（ローカル開発ではデフォルトで file:local.db が使われるため設定不要）
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

# Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
# local / production: 本物の値を入れる
# OAuth エミュレータ利用時（pnpm dev:preview / Vercel preview）: ダミー値
# (client=emulate-client / secret=emulate-secret) で動く。
# あわせて NEXT_PUBLIC_VERCEL_ENV=preview で @emulators/google が有効化される
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vercel AI Gateway
# ローカルは API キー必須。Vercel 上は OIDC で自動認証されるため不要
AI_GATEWAY_API_KEY=
# <provider>/<model> 形式で差し替え可能（既定: google/gemini-2.5-flash）
# claude 系は Vercel 有料クレジットが必要
# AI_GATEWAY_MODEL=anthropic/claude-sonnet-4-6
